import pandas as pd
import numpy as np
import os
from datetime import datetime
from sklearn.ensemble import RandomForestRegressor

#  Load Data
df = pd.read_csv("/content/cleaned_stock_data.csv")
df['Date'] = pd.to_datetime(df['Date'])


#  Feature Engineering

df['Lag_1'] = df['Close'].shift(1)
df['Lag_2'] = df['Close'].shift(2)

df['Target'] = df['Close'].shift(-1)

df = df.dropna()


#  Feature Selection

features = ['Lag_1', 'Lag_2', 'Volume']
X = df[features]
y = df['Target']


#  Train Random Forest
rf = RandomForestRegressor(n_estimators=100, max_depth=6, random_state=42)
rf.fit(X, y)


#  Save Function

def save_to_excel(data):
    file = "predictions.xlsx"
    
    if os.path.exists(file):
        old = pd.read_excel(file)
        data = pd.concat([old, data], ignore_index=True)
    
    data.to_excel(file, index=False)


#  User Prediction

def predict_user():
    
    ticker = input("\nEnter Ticker: ").upper()
    input_date = input("Enter Input Date (YYYY-MM-DD): ")
    
    lag1 = float(input("Enter Lag_1: "))
    lag2 = float(input("Enter Lag_2: "))
    volume = float(input("Enter Volume: "))
    
    input_data = pd.DataFrame([{
        'Lag_1': lag1,
        'Lag_2': lag2,
        'Volume': volume
    }])
    
    pred_rf = rf.predict(input_data)[0]
    
    next_day = pd.to_datetime(input_date) + pd.Timedelta(days=1)
    
    print("\n Random Forest Prediction:", pred_rf)
    
    # Save
    row = pd.DataFrame([{
        'Input_Date': input_date,
        'Prediction_For': next_day,
        'Ticker': ticker,
        'Lag_1': lag1,
        'Lag_2': lag2,
        'Volume': volume,
        'RF_Prediction': pred_rf,
        'Actual': None
    }])
    
    save_to_excel(row)

#  Run

predict_user()
